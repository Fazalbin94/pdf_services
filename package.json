{
  "name": "pdf-service",
  "version": "1.0.0",
  "description": "Dynamic PDF generation microservice with configurable templates",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed:pdf": "tsx prisma/seed-pdf-service.ts",
    "seed:pdf:dev": "dotenv -e .env.development -- tsx prisma/seed-pdf-service.ts",
    "seed:pdf:prod": "dotenv -e .env.production -- tsx prisma/seed-pdf-service.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^6.19.1",
    "@supabase/supabase-js": "^2.87.3",
    "@xmldom/xmldom": "^0.8.11",
    "busboy": "^1.6.0",
    "canvas": "^3.2.0",
    "fastify": "^4.26.2",
    "file-type": "^21.3.0",
    "jsonwebtoken": "^9.0.2",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "puppeteer": "^24.34.0",
    "puppeteer-core": "^24.34.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.19.27",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
